rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Åpent for utvikling — stram inn før prod
    match /{document=**} {
      allow read, write: if true;
    }

    // Prosessdefinisjoner — tilgangskontroll per org/bruker
    // TODO: Stram inn til orgId-basert tilgang før prod
    match /processDefinitions/{processId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;

      match /versions/{versionId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }
  }
}
